# Docker
*.pid
*.seed

# Better Auth SQLite database — never commit (contains password hashes, sessions)
apps/api/data/auth.sqlite
apps/api/data/auth.sqlite-journal
apps/api/data/auth.sqlite-wal
apps/api/data/auth.sqlite-shm

# Proprietary Pro-map source data — never commit. Shipped out-of-band to the
# VPS bind-mount dir /opt/wce/data/private/ (boundaries.geojson + wra_masts.csv),
# which is where the running API actually reads them. See deploy/REFERENCE.md §6.1.
apps/api/data/private/

# Regenerable Overpass tile-ingest cache (raw OSM JSON for the wind_turbines
# table) — never commit; re-created by scripts/ingest-turbines.ts.
apps/api/data/cache/

# Source wind-exclusion KMZ SuperOverlays (~33 MB). Baked into the committed
# XYZ pyramid apps/web/public/exclusions/ by scripts/build_exclusions.py — the
# baked tiles ship in the repo (like wind-atlas), the bulky source does not.
apps/api/data/exclusion/


# IDE
.vscode/
.idea/

# Python
__pycache__/
*.pyc

# RAG ingestion subsystem (Python)
ingestion/.env
ingestion/.venv/
ingestion/data/pdfs/
ingestion/data/docx/
ingestion/data/parsed/
ingestion/qdrant_storage/

# Qdrant snapshots — large binaries, copied to the VPS via scp (see DEPLOY.md)
deploy/*.snapshot