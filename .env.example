# ── API Server ─────────────────────────────────────────────────────────────────
PORT=3005

# ── Security ────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
WPI_ADMIN_TOKEN=changeme-please-set-a-long-random-string

# ── CRON Schedule (UTC) ─────────────────────────────────────────────────────────
# Default: 01:00 UTC = 06:30 IST
WPI_CRON_SCHEDULE=0 1 * * *

# ── CORS ────────────────────────────────────────────────────────────────────────
# Set to your production domain(s) in deployment. Must list the web app origin
# so the browser is allowed to send the auth cookie cross-origin.
WPI_ALLOW_ORIGINS=http://localhost:3006

# ── Frontend ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3005

# ── Better Auth ────────────────────────────────────────────────────────────────
# Required. Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=changeme-32-char-min-random-string-please-rotate
# The auth server's own base URL (where /api/auth/* is mounted)
BETTER_AUTH_URL=http://localhost:3005
# Origins allowed to call auth endpoints with credentials (comma-separated)
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3006
# Prod only: set to .windpowerindia.com so the session cookie works on
# both windpowerindia.com and api.windpowerindia.com. Leave unset in dev.
# AUTH_COOKIE_DOMAIN=.windpowerindia.com

# ── Pro access (no Stripe yet) ─────────────────────────────────────────────────
# Comma-separated emails granted Pro tier without paying. Replace with [] when
# Stripe webhook flips tier=PREMIUM on the user record.
PRO_ALLOWLIST_EMAILS=

# ── Email (Resend) ─────────────────────────────────────────────────────────────
# Get from https://resend.com — free tier covers <3k emails/month.
# If unset, OTPs are logged to the API console instead of emailed (dev only).
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev

# ── RAG Chatbot ────────────────────────────────────────────────────────────────
# OpenAI is used for query-time embeddings (text-embedding-3-small — must match
# ingestion). It is ALSO used for generation if XAI_API_KEY below is empty.
OPENAI_API_KEY=
# Optional: switch chat generation to xAI Grok. If XAI_API_KEY is set, the chat
# route uses Grok via the OpenAI-compatible xAI endpoint and OpenAI is only
# used for embeddings. Leave unset to keep the o4-mini path.
XAI_API_KEY=
XAI_MODEL=grok-4-fast-reasoning
# Qdrant: dev = local Docker via ingestion/docker-compose.yml; prod = VPS
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=wind_energy_v1
