# Copy to /opt/wce/.env on the VPS, then fill in real values.
# Generate the admin token with: openssl rand -hex 32

WPI_ADMIN_TOKEN=REPLACE_ME_WITH_LONG_RANDOM_HEX
WPI_CRON_SCHEDULE=0 1 * * *
WPI_ALLOW_ORIGINS=https://windpowerindia.com,https://www.windpowerindia.com

# ── Umami analytics ───────────────────────────────────────────────────────────
# Generate both with: openssl rand -hex 32
UMAMI_DB_PASSWORD=REPLACE_ME_WITH_LONG_RANDOM_HEX
UMAMI_APP_SECRET=REPLACE_ME_WITH_LONG_RANDOM_HEX

# Fill these in AFTER first-time Umami setup at https://analytics.windpowerindia.com
# (log in with the default admin/umami, change the password, add a website, copy its ID).
# Leave blank to disable the tracking snippet entirely.
NEXT_PUBLIC_UMAMI_SCRIPT_URL=https://analytics.windpowerindia.com/script.js
NEXT_PUBLIC_UMAMI_WEBSITE_ID=

# ── Admin dashboard (/admin/*) ────────────────────────────────────────────────
# /admin/* is gated by an in-app JWT cookie. The login page lives at
# /admin/login. ADMIN_USERNAME + ADMIN_PASSWORD are the only credentials
# that can sign in; the JWT is signed with ADMIN_JWT_SECRET (must be at
# least 32 chars — generate with `openssl rand -hex 32`).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
ADMIN_JWT_SECRET=REPLACE_ME_WITH_LONG_RANDOM_HEX

# The dashboard fetches stats from Umami's REST API server-side. Self-
# hosted Umami's open-source UI doesn't expose static API keys, so the app
# logs in with the admin username/password and caches the returned Bearer
# token in memory. Credentials never reach the browser.
UMAMI_API_URL=https://analytics.windpowerindia.com
UMAMI_USERNAME=admin
UMAMI_PASSWORD=

# ── Better Auth (user accounts + Pro gating) ──────────────────────────────────
# Required. Generate with: openssl rand -hex 32. Use a NEW value in prod — do not
# reuse the dev secret. Rotating it invalidates all existing sessions.
BETTER_AUTH_SECRET=REPLACE_ME_WITH_LONG_RANDOM_HEX
# BETTER_AUTH_URL, BETTER_AUTH_TRUSTED_ORIGINS and AUTH_COOKIE_DOMAIN are
# hard-coded to the prod hostnames in deploy/docker-compose.prod.yml — no need
# to set them here.
#
# Comma-separated emails granted Pro tier without paying (chat is Pro-gated).
PRO_ALLOWLIST_EMAILS=
# Email delivery (Resend). If blank, auth still works (OTP/verification are
# disabled); only needed once email flows are turned on. https://resend.com
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev

# ── RAG chatbot ───────────────────────────────────────────────────────────────
# OpenAI is REQUIRED — it does query-time embeddings (text-embedding-3-small,
# must match ingestion) and is the generation fallback.
OPENAI_API_KEY=
# Optional: xAI Grok is the PRIMARY generation provider when set. On any failure
# or rate-limit it falls back to OpenAI o4-mini automatically. Leave blank to use
# OpenAI for generation too.
XAI_API_KEY=
XAI_MODEL=grok-4-fast-reasoning
# Qdrant runs as the `qdrant` service in docker-compose.prod.yml. The API reaches
# it in-network at http://qdrant:6333 (QDRANT_URL is set in the compose file).
# This key is shared by the qdrant container AND the api container — generate
# once with: openssl rand -hex 32
QDRANT_API_KEY=REPLACE_ME_WITH_LONG_RANDOM_HEX
QDRANT_COLLECTION=wind_energy_v1
