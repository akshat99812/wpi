# Copy to /opt/wce/.env on the VPS, then fill in real values.
# Generate the admin token with: openssl rand -hex 32

WPI_ADMIN_TOKEN=REPLACE_ME_WITH_LONG_RANDOM_HEX
WPI_CRON_SCHEDULE=0 1 * * *
WPI_ALLOW_ORIGINS=https://windpowerindia.com,https://www.windpowerindia.com

# ── Umami analytics ───────────────────────────────────────────────────────────
# Generate both with: openssl rand -hex 32
UMAMI_DB_PASSWORD=REPLACE_ME_WITH_LONG_RANDOM_HEX
UMAMI_APP_SECRET=REPLACE_ME_WITH_LONG_RANDOM_HEX

# Fill these in AFTER first-time Umami setup at https://analytics.windpowerindia.com
# (log in with the default admin/umami, change the password, add a website, copy its ID).
# Leave blank to disable the tracking snippet entirely.
NEXT_PUBLIC_UMAMI_SCRIPT_URL=https://analytics.windpowerindia.com/script.js
NEXT_PUBLIC_UMAMI_WEBSITE_ID=

# ── Admin dashboard (/admin/analytics) ────────────────────────────────────────
# Comma-separated Google IDs (numeric "sub" claim) allowed to access /admin/*.
# Find yours by signing in and visiting /api/auth/session — it's user.googleId.
ADMIN_GOOGLE_IDS=

# Umami v2 REST API. The dashboard fetches stats server-side with this token;
# the token never reaches the browser. Token is generated in Umami at
# Settings → Profile → API Keys.
UMAMI_API_URL=https://analytics.windpowerindia.com
UMAMI_API_TOKEN=
